          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/courses/{{courseSlug}}"
          }
        },
        {
          "name": "List units for course",
          "event": [
            {
              "listen": "prerequest",
              "script": {
