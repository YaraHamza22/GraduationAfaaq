          }
        },
        {
          "name": "Mark notification read",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const id = pm.collectionVariables.get('notificationId');",
                  "if (!id || id === 'uuid-from-notifications-list') {",
                  "  throw new Error('Run \"List my notifications\" and set collection variable notificationId to a real UUID.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "pm.test('API status success', () => pm.expect(j.status).to.eql('success'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auditor/notifications/{{notificationId}}/read",
            "description": "Use notification `id` (UUID) from list response — not numeric 1."
          }
        },
        {
          "name": "Mark all notifications read",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auditor/notifications/read-all"
          }
        }
      ]
    }
  ]
}
